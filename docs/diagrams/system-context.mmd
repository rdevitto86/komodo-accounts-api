flowchart TD
    Internet([Internet])
    BFF["UI / BFF"]
    Services["Sibling Komodo services<br/>auth · payments · order · comms"]

    subgraph Accounts["Komodo Accounts API — account identity store"]
        direction LR
        Pub["public plane<br/>profile · addresses · payments · unsubscribe"]
        Priv["private plane<br/>credential lookup · VPC-internal only"]
    end

    Events["events-api<br/>change fan-out"]
    Downstream["loyalty · comms · promotions · insights"]

    Internet --> BFF
    BFF -->|"public REST"| Pub
    Services -->|"private REST"| Priv
    Accounts -->|"account events"| Events
    Events --> Downstream

    Note["Account identity store — not the authenticator.<br/>auth-api owns sign-in and token issuance."]
    Pub -.- Note
    Priv -.- Note

    classDef publicPlane fill:#CDEDE8,stroke:#2A9D8F,color:#12403A;
    classDef privatePlane fill:#DDD8F5,stroke:#5B4FB0,color:#2A2456;
    classDef dataLayer fill:#F3E3C3,stroke:#C9973B,color:#5A4413;
    classDef external fill:#E7E9EC,stroke:#9AA1A9,color:#33383D;
    classDef pipeline fill:#D9E7CC,stroke:#7A9A65,color:#334524;

    class Pub publicPlane;
    class Priv privatePlane;
    class Internet,BFF,Services,Downstream external;
    class Events pipeline;

    style Pub stroke-width:3px;
    style Priv stroke-width:3px;
    style Accounts fill:#FBFBFD,stroke:#B9BFC7,stroke-width:1px;
